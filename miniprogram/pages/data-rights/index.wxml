<view class="data-rights-page">
  <view class="section">
    <view class="menu-item" bindtap="onClearLocalCache">
      <text>清理本地缓存</text>
      <text class="menu-desc">仅清理本地缓存，不影响云端记录</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item danger" bindtap="onDeleteMyData">
      <text>删除我的全部数据</text>
      <text class="menu-desc">删除后无法恢复，请谨慎操作</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
