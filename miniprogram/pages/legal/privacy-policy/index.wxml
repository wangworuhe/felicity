<view class="legal-page">
  <view class="header">
    <text class="title">{{guideTitle}}</text>
  </view>

  <view class="section">
    <text class="line">{{intro}}</text>
  </view>

  <view class="section" wx:for="{{sections}}" wx:key="title">
    <text class="section-title">{{item.title}}</text>
    <text class="line" wx:for="{{item.lines}}" wx:key="*this">{{item}}</text>
  </view>
</view>
