.legal-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 14px 12px 20px;
  box-sizing: border-box;
}

.header {
  background: #fff;
  border-radius: 10px;
  padding: 12px;
  margin-bottom: 10px;
}

.title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #222;
  margin-bottom: 6px;
}

.meta {
  display: block;
  font-size: 12px;
  color: #777;
  margin-bottom: 2px;
}

.card {
  background: #fff;
  border-radius: 10px;
  padding: 12px;
  margin-bottom: 10px;
}

.name {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #222;
  margin-bottom: 8px;
}

.row {
  min-height: 30px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  border-bottom: 1px solid #f3f3f3;
  padding: 5px 0;
}

.row:last-child {
  border-bottom: none;
}

.label {
  width: 70px;
  font-size: 12px;
  color: #666;
}

.value {
  flex: 1;
  font-size: 12px;
  color: #333;
  text-align: right;
  word-break: break-all;
}

.link {
  color: #3f6ecb;
}
