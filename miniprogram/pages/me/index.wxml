<view class="me-page">
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>
  <block wx:else>
  <view class="profile-card">
    <view class="avatar-wrapper">
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{userProfile.avatarPreview || defaultAvatar}}" mode="aspectFill" />
      </button>
    </view>
    <view class="nickname-area" bindtap="onEditNickName">
      <text class="nickname-display">{{userProfile.nickName}}</text>
      <image class="nickname-edit-icon" src="../../images/icons/edit.svg" />
    </view>
  </view>

  <view class="section">
    <view class="section-title">我的数据</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-num">{{summary.happinessCount}}</text>
        <text class="stat-label">幸福</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{summary.fortuneCount}}</text>
        <text class="stat-label">反思</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{summary.diaryCount}}</text>
        <text class="stat-label">手账</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{summary.totalCount}}</text>
        <text class="stat-label">总计</text>
      </view>
    </view>
    <view class="info-row">
      <text class="label">最近活跃</text>
      <text class="value">{{summary.latestActiveAt}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">协议与隐私</view>
    <view class="menu-item" bindtap="onOpenLegal" data-page="user-agreement">
      <text>用户协议</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onOpenLegal" data-page="privacy-policy">
      <text>隐私政策</text>
      <text class="arrow">></text>
    </view>
<view class="menu-item" bindtap="onOpenPrivacyContract">
      <text>隐私保护指引</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="onOpenPermissions">
      <text>权限管理</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="section">
    <view class="menu-item" bindtap="onOpenDataRights">
      <text>数据权利</text>
      <text class="arrow">></text>
    </view>
  </view>
  </block>
</view>
