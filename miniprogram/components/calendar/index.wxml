<view class="calendar">
  <!-- 月份导航 -->
  <view class="calendar-header">
    <view class="nav-btn" bindtap="onPrevMonth">
      <text class="nav-arrow">‹</text>
    </view>
    <view class="month-title-wrap" bindtap="onMonthTitleTap">
      <text class="month-title">{{displayYear}}年{{displayMonth}}月</text>
    </view>
    <view class="nav-btn" bindtap="onNextMonth">
      <text class="nav-arrow">›</text>
    </view>
    <view class="today-btn" bindtap="onGoToday" wx:if="{{!isCurrentMonth}}">
      <text class="today-btn-text">今</text>
    </view>
  </view>

  <!-- 年月选择器 -->
  <view class="picker-mask" wx:if="{{showPicker}}" catchtap="onClosePicker"></view>
  <view class="picker-panel" wx:if="{{showPicker}}" catchtap="">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="onClosePicker">取消</text>
      <text class="picker-title">选择年月</text>
      <text class="picker-confirm" bindtap="onPickerConfirm">确定</text>
    </view>
    <picker-view class="picker-view" value="{{pickerValue}}" bindchange="onPickerChange">
      <picker-view-column>
        <view class="picker-item" wx:for="{{pickerYears}}" wx:key="*this">{{item}}年</view>
      </picker-view-column>
      <picker-view-column>
        <view class="picker-item" wx:for="{{pickerMonths}}" wx:key="*this">{{item}}月</view>
      </picker-view-column>
    </picker-view>
  </view>

  <!-- 星期头 -->
  <view class="weekday-row">
    <view class="weekday-cell" wx:for="{{weekdays}}" wx:key="*this">
      <text class="weekday-text">{{item}}</text>
    </view>
  </view>

  <!-- 日期格子（支持滑动切月） -->
  <view
    class="days-grid"
    bindtouchstart="onTouchStart"
    bindtouchend="onTouchEnd"
  >
    <view
      class="day-cell"
      wx:for="{{days}}"
      wx:key="date"
      bindtap="onDayTap"
      data-day="{{item}}"
    >
      <view class="day-inner {{item.isSelected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}} {{!item.isCurrentMonth ? 'other-month' : ''}}">
        <text class="day-text">{{item.day}}</text>
        <view class="dot" wx:if="{{item.hasRecord && item.isCurrentMonth}}"></view>
      </view>
    </view>
  </view>
</view>
