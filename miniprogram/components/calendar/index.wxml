<view class="calendar">
  <!-- 顶部：月份标题 -->
  <view class="calendar-header">
    <view class="month-title-wrap" bindtap="onMonthTitleTap">
      <text class="month-title">{{displayLabel}}</text>
      <text class="month-title-arrow">▾</text>
    </view>
    <view class="today-btn" bindtap="onGoToday">
      <text class="today-btn-text">今</text>
    </view>
  </view>

  <!-- 星期行 -->
  <view class="weekday-row">
    <view class="weekday-cell" wx:for="{{weekdays}}" wx:key="*this">
      <text class="weekday-text">{{item}}</text>
    </view>
  </view>

  <!-- 滚动日期区域 -->
  <scroll-view
    class="weeks-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bounces="{{false}}"
    scroll-into-view="{{scrollIntoView}}"
    scroll-with-animation="{{false}}"
    bindscroll="onScroll"
    bindscrolltoupper="onScrollToUpper"
    upper-threshold="100"
    style="height: {{scrollHeight}}px;"
  >
    <block wx:for="{{months}}" wx:key="key" wx:for-item="monthBlock" wx:for-index="monthIdx">
      <!-- 周行 -->
      <view
        class="week-row {{weekIdx === 0 ? 'month-anchor' : ''}}"
        wx:for="{{monthBlock.weeks}}"
        wx:key="weekId"
        wx:for-item="week"
        wx:for-index="weekIdx"
        id="{{weekIdx === 0 ? monthBlock.key : week.weekId}}"
        data-year="{{monthBlock.year}}"
        data-month="{{monthBlock.month}}"
      >
        <view
          class="day-cell"
          wx:for="{{week.days}}"
          wx:key="date"
          wx:for-item="dayItem"
          bindtap="onDayTap"
          data-day="{{dayItem}}"
        >
          <view class="day-inner {{dayItem.isSelected ? 'selected' : ''}} {{dayItem.isToday ? 'today' : ''}} {{!dayItem.isCurrentMonth ? 'other-month' : ''}} {{dayItem.isFuture ? 'future' : ''}}">
            <text class="day-text">{{dayItem.day}}</text>
            <view class="dot" wx:if="{{dayItem.hasRecord && dayItem.isCurrentMonth}}"></view>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <!-- 年月选择器 -->
  <view class="picker-mask" wx:if="{{showPicker}}" catchtap="onClosePicker"></view>
  <view class="picker-panel" wx:if="{{showPicker}}" catchtap="">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="onClosePicker">取消</text>
      <text class="picker-title">选择年月</text>
      <text class="picker-confirm" bindtap="onPickerConfirm">确定</text>
    </view>
    <picker-view class="picker-view" value="{{pickerValue}}" bindchange="onPickerChange">
      <picker-view-column>
        <view class="picker-item" wx:for="{{pickerYears}}" wx:key="*this">{{item}}年</view>
      </picker-view-column>
      <picker-view-column>
        <view class="picker-item" wx:for="{{pickerMonths}}" wx:key="*this">{{item}}月</view>
      </picker-view-column>
    </picker-view>
  </view>
</view>
